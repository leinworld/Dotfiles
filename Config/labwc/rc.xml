<!--
  This is a very simple config file with many options missing. For a complete
  set of options with comments, see docs/rc.xml.all
-->

<labwc_config>

  <theme>
    <name>Clearlooks-3.4</name>
    <cornerRadius>8</cornerRadius>
    <font name="sans" size="10" />
    <dropShadows>yes</dropShadows>
  </theme>

  <desktops>
    <number>5</number>
  </desktops>

  <keyboard>
    <default />
    <!-- Use a different terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute" command="kitty" />
    </keybind>
    <!--
      Remove a previously defined keybind
      A shorter alternative is <keybind key="W-F4" />
    -->
    <keybind key="W-F4">
      <action name="None" />
    </keybind>
    <keybind key="W-E">
      <action name="Execute" command="thunar" />
    </keybind>
    <keybind key="W-Space">
      <action name="Execute" command="fuzzel" />
    </keybind>
    <!-- 화면 밝기 조절 -->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute" command="brightnessctl set +5%" />
    </keybind>
    <keybind key="XF86MonBrightnessDown">
      <action name="Execute" command="brightnessctl set 5%-" />
    </keybind>

    <!-- 볼륨 조절 (최대 100% 제한 적용) -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ --limit 1.0" />
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute" command="wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-" />
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute" command="wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle" />
    </keybind>
  </keyboard>

  <mouse>
    <default />
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="some-custom-menu" />
      </mousebind>
      <mousebind button="Left" action="Press" />
    </context>
  </mouse>

</labwc_config>
